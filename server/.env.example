# 存储驱动：json（默认）| postgres
STORAGE_DRIVER=json
# json 模式下的元数据目录（uploads/ 仍存解压后的原型文件）
JSON_STORE_PATH=./data

# postgres 模式必填；json 模式可省略
# DATABASE_URL=postgres://protohost:change_me@localhost:5434/protohost

JWT_SECRET=replace_with_base64_secret_at_least_32_chars_long
JWT_EXPIRATION=604800
JWT_VIEW_EXPIRATION=7200
UPLOAD_BASE_PATH=./uploads
PORT=3000
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
DEFAULT_USER_ENABLED=true
DEFAULT_USER_EMAIL=admin
DEFAULT_USER_PASSWORD=Admin1234
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
