# 存储驱动：json（默认，本地 JSON 文件，无需 PostgreSQL）| postgres
STORAGE_DRIVER=json
JSON_STORE_PATH=./data

# PostgreSQL（仅 STORAGE_DRIVER=postgres 时需要；Docker 对外 5434）
# PG_PASSWORD=change_me
# DATABASE_URL=postgres://protohost:change_me@localhost:5434/protohost

# Security
JWT_SECRET=replace_with_base64_secret_at_least_32_chars_long
JWT_EXPIRATION=604800
JWT_VIEW_EXPIRATION=7200

# Default user (auto-created on first startup)
DEFAULT_USER_ENABLED=true
DEFAULT_USER_EMAIL=admin
DEFAULT_USER_PASSWORD=Admin1234

# Email (optional; smtp.example.com = mock log only)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Docker HTTP port for frontend nginx
HTTP_PORT=8080
CORS_ORIGINS=http://localhost:8080,http://localhost:5173
